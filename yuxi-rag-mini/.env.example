# Database
DB_TYPE=sqlite
SQLITE_PATH=data/yuxi_rag.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/yuxi_rag

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB=yuxi_rag

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=data/files
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=yuxi-rag
# MINIO_SECURE=false

# Embedding
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=40

# Rerank
RERANK_PROVIDER=dummy
