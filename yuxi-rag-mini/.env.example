# Database
DB_TYPE=sqlite
SQLITE_PATH=data/yuxi_rag.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/yuxi_rag

# Milvus
# Use http://localhost:19530 for Milvus Standalone (Docker), or data/milvus.db for Milvus Lite (embedded)
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB=yuxi_rag

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=data/files
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=yuxi-rag
# MINIO_SECURE=false

# Embedding
# Provider options: openai_compatible, ollama, huggingface, fake
# WARNING: "fake" provider generates meaningless vectors, only for testing!
# For real RAG and resume demonstrations, use a real embedding provider.
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=128
EMBEDDING_BATCH_SIZE=40
EMBEDDING_TIMEOUT=60
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# Rerank
# Current version provides rerank interface with DummyReranker.
# Real rerank model can be plugged in later.
RERANK_PROVIDER=dummy

# LLM (OpenAI-compatible Chat Completions, used by /api/kb/{kb_id}/chat)
# Works with OpenAI, any OpenAI-compatible service, or local Ollama (/v1 endpoint).
#
# OpenAI example:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_api_key
# LLM_MODEL=gpt-4o-mini
#
# Local Ollama example (run `ollama serve`, then pull a model with `ollama pull qwen2.5:7b`):
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT=60
