# Database
DB_TYPE=sqlite
SQLITE_PATH=data/yuxi_rag.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/yuxi_rag

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB=yuxi_rag

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=data/files
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=yuxi-rag
# MINIO_SECURE=false

# Embedding
# Provider options: openai_compatible, ollama, huggingface, fake
# WARNING: "fake" provider generates meaningless vectors, only for testing!
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=bge-m3
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=128
EMBEDDING_BATCH_SIZE=40
EMBEDDING_CHUNK_SIZE=512
EMBEDDING_CHUNK_OVERLAP=50

# Rerank
RERANK_PROVIDER=dummy
